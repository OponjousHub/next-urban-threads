generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String         @id @default(cuid())
  email                        String         @unique
  createdAt                    DateTime       @default(now())
  address                      String?
  city                         String?
  country                      String?
  password                     String
  phone                        String?
  role                         Role           @default(USER)
  updatedAt                    DateTime       @updatedAt
  deletedAt                    DateTime?
  isDeleted                    Boolean        @default(false)
  avatarUrl                    String?
  name                         String?
  status                       AccountStatus  @default(ACTIVE)
  emailTokenExpiry             DateTime?
  emailVerifyToken             String?
  pendingEmail                 String?
  tenantId                     String
  passwordUpdatedAt            DateTime?
  twoFactorEnabled             Boolean        @default(false)
  twoFactorSecret              String?
  twoFactorTempSecret          String?
  twoFactorTempSecretExpiresAt DateTime?
  recoveryCodes                String[]
  deactivatedAt                DateTime?
  resetToken                   String?        @unique
  resetTokenExpiry             DateTime?
  addresses                    Address[]
  cartItems                    CartItem[]
  orders                       Order[]
  products                     Product[]      @relation("UserProduct")
  reviews                      Review[]
  session                      Session[]
  tenant                       Tenant         @relation(fields: [tenantId], references: [id])
  wishlistItem                 WishlistItem[]
}

model Product {
  id              String         @id @default(cuid())
  price           Decimal        @db.Decimal(10, 2)
  discountedPrice Decimal?       @db.Decimal(10, 2)
  name            String
  slug            String
  description     String?
  thumbnail       String
  sizes           String[]
  colours         String[]
  stock           Int            @default(0)
  instock         Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subCategory     String
  seoTitle        String?
  seoDescription  String?
  deletedAt       DateTime?
  images          String[]
  createdByName   String?
  featured        Boolean        @default(false)
  createdById     String?
  tenantId        String
  averageRating   Float          @default(0)
  reviewCount     Int            @default(0)
  rating1Count    Int            @default(0)
  rating2Count    Int            @default(0)
  rating3Count    Int            @default(0)
  rating4Count    Int            @default(0)
  rating5Count    Int            @default(0)
  vendorId        String?
  categoryId      String
  isFlashDeal     Boolean        @default(false)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category       @relation(fields: [categoryId], references: [id])
  user            User?          @relation("UserProduct", fields: [createdById], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  reviews         Review[]
  wishlistItem    WishlistItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Order {
  id                String          @id @default(cuid())
  userId            String
  createdAt         DateTime        @default(now())
  status            OrderStatus     @default(PENDING)
  paymentMethod     String
  totalAmount       Decimal
  currency          String
  paymentProvider   PaymentProvider
  paymentReference  String          @unique
  shippingAddressId String
  paymentStatus     PaymentStatus   @default(PENDING)
  tenantId          String
  vendorId          String?
  shippingAddress   Address         @relation(fields: [shippingAddressId], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  user              User            @relation(fields: [userId], references: [id])
  items             OrderItem[]
  review            Review[]
  orderTrackingEvent OrderTrackingEvent[]
  orderStatusHistory OrderStatusHistory[]

  @@index([tenantId, createdAt, status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  tenantId  String
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  fullName    String?
  phone       String?
  street      String
  city        String
  state       String?
  postalCode  String?
  country     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isTemporary Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
}

model Tenant {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  domain             String?
  isDefault          Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  autoApproveReviews Boolean        @default(false)
  reviewPolicy       ReviewPolicy   @default(AFTER_PAYMENT)
  currency           String         @default("USD")
  email              String?
  logo               String?
  timezone           String         @default("UTC")
  primaryColor       String?
  storeType          StoreType      @default(SINGLE_VENDOR)
  returnPolicy       String?
  shippingPolicy     String?
  aboutTitle         String?
  aboutText          String?
  aboutStory         String?
  aboutImage         String?
  address            Address[]
  cartItem           CartItem[]
  categories         Category[]
  contact            Contact[]
  tenant             FAQ[]
  newsletter         Newsletter[]
  orders             Order[]
  products           Product[]
  review             Review[]
  users              User[]
  WishlistItem       WishlistItem[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  userAgent    String?
  ipAddress    String?
  deviceName   String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Review {
  id               String       @id @default(cuid())
  userId           String
  rating           Int
  comment          String
  createdAt        DateTime     @default(now())
  productId        String
  tenantId         String
  orderId          String?
  updatedAt        DateTime     @updatedAt
  status           ReviewStatus @default(PENDING)
  repliedAt        DateTime?
  reply            String?
  helpfulCount     Int          @default(0)
  images           String[]
  title            String?
  verifiedPurchase Boolean      @default(false)
  order            Order?       @relation(fields: [orderId], references: [id])
  product          Product      @relation(fields: [productId], references: [id])
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  user             User         @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([tenantId])
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  tenantId  String
  product   Product @relation(fields: [productId], references: [id])
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  tenantId  String
  product   Product @relation(fields: [productId], references: [id])
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model Vendor {
  id       String @id @default(cuid())
  name     String
  tenantId String
}

model Category {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  image      String?
  tenantId   String
  isFeatured Boolean   @default(true)
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  products   Product[]
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  tenantId  String
  createdAt DateTime      @default(now())
  priority  Priority      @default(NORMAL)
  status    ContactStatus @default(UNREAD)
  tag       ContactTag?
  updatedAt DateTime      @updatedAt
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String

  category  String   @default("General") 
  order     Int      @default(0)         

  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  status    String   // "PAID", "SHIPPED", etc
  message   String?  // human-readable update
  location  String?  // optional (e.g. "Lagos Hub")
  
  createdAt DateTime @default(now())
}

model OrderTrackingEvent {
  id          String   @id @default(cuid())

  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])

  tenantId    String
  type        TrackingEventType  // ✅ ENUM
  status      OrderStatus?       // ✅ OPTIONAL ENUM

  title       String
  description String?            // ✅ keep only this (remove message)

  location    String?
  metadata    Json?

  createdAt   DateTime @default(now())
}

enum ContactStatus {
  UNREAD
  READ
  RESOLVED
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

enum ContactTag {
  BUG
  ORDER
  REFUND
  GENERAL
}

enum Role {
  USER
  ADMIN
  OWNER
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  FAILED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum StoreType {
  SINGLE_VENDOR
  MULTI_VENDOR
}

enum Currency {
  NGN
  USD
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ReviewPolicy {
  AFTER_PAYMENT
  AFTER_DELIVERY
  MANUAL_APPROVAL
}

enum TrackingEventType {
  STATUS_CHANGE
  COURIER_UPDATE
  NOTE
  SYSTEM
}