generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String              @id @default(cuid())
  email                        String              @unique
  createdAt                    DateTime            @default(now())
  address                      String?
  city                         String?
  country                      String?
  password                     String
  phone                        String?
  role                         Role                @default(USER)
  updatedAt                    DateTime            @updatedAt
  deletedAt                    DateTime?
  isDeleted                    Boolean             @default(false)
  avatarUrl                    String?
  name                         String?
  status                       AccountStatus       @default(ACTIVE)
  emailTokenExpiry             DateTime?
  emailVerifyToken             String?
  pendingEmail                 String?
  tenantId                     String
  passwordUpdatedAt            DateTime?
  twoFactorEnabled             Boolean             @default(false)
  twoFactorSecret              String?
  twoFactorTempSecret          String?
  twoFactorTempSecretExpiresAt DateTime?
  recoveryCodes                String[]
  deactivatedAt                DateTime?
  resetToken                   String?             @unique
  resetTokenExpiry             DateTime?
  vendorId                     String?
  addresses                    Address[]
  cartItems                    CartItem[]
  orders                       Order[]
  products                     Product[]           @relation("UserProduct")
  refundRequest                RefundRequest[]
  reviews                      Review[]
  session                      Session[]
  storeFollow                  StoreFollow[]
  tenant                       Tenant              @relation(fields: [tenantId], references: [id])
  vendor                       Vendor?             @relation(fields: [vendorId], references: [id])
  vendorApplications           VendorApplication[]
  wishlistItem                 WishlistItem[]
}

model Product {
  id              String           @id @default(cuid())
  price           Decimal          @db.Decimal(10, 2)
  discountedPrice Decimal?         @db.Decimal(10, 2)
  name            String
  slug            String
  description     String?
  thumbnail       String
  sizes           String[]
  colours         String[]
  stock           Int              @default(0)
  instock         Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  subCategory     String
  seoTitle        String?
  seoDescription  String?
  deletedAt       DateTime?
  images          String[]
  createdByName   String?
  featured        Boolean          @default(false)
  createdById     String?
  tenantId        String
  averageRating   Float            @default(0)
  reviewCount     Int              @default(0)
  rating1Count    Int              @default(0)
  rating2Count    Int              @default(0)
  rating3Count    Int              @default(0)
  rating4Count    Int              @default(0)
  rating5Count    Int              @default(0)
  vendorId        String?
  categoryId      String
  isFlashDeal     Boolean          @default(false)
  videos          Json?
  storeMode       StoreMode        @default(SINGLE_VENDOR)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  category        Category         @relation(fields: [categoryId], references: [id])
  user            User?            @relation("UserProduct", fields: [createdById], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  vendor          Vendor?          @relation(fields: [vendorId], references: [id])
  variants        ProductVariant[]
  refundItem      RefundItem[]
  reviews         Review[]
  wishlistItem    WishlistItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Vendor {
  id               String             @id @default(cuid())
  name             String
  banner           String?
  createdAt        DateTime           @default(now())
  description      String?
  email            String?
  logo             String?
  phone            String?
  slug             String             @unique
  status           VendorStatus       @default(PENDING)
  updatedAt        DateTime           @updatedAt
  tenantId         String
  suspensionReason String?
  adminNotes       String?
  accentColor      String?            @default("#000000")
  accountName      String?
  accountNumber    String?
  bankName         String?
  facebookUrl      String?
  instagramUrl     String?
  privacyPolicy    String?
  returnPolicy     String?
  shippingPolicy   String?
  terms            String?
  twitterUrl       String?
  websiteUrl       String?
  youtubeUrl       String?
  address          String?
  city             String?
  country          String?
  state            String?
  storeSlug        String?            @unique @db.VarChar(100)
  termsOfService   String?
  linkedinUrl      String?
  tiktokUrl        String?
  whatsapp         String?
  coupon           Coupon[]
  orders           Order[]
  products         Product[]
  users            User[]
  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  bankAccount      VendorBankAccount?
  payouts          VendorPayout[]
  storeFollow      StoreFollow[]
}

model VendorApplication {
  id              String                  @id @default(cuid())
  userId          String
  businessName    String
  businessEmail   String?
  businessPhone   String?
  description     String?
  status          VendorApplicationStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  tenantId        String
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])
  user            User                    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model VendorBankAccount {
  id            String   @id @default(cuid())
  vendorId      String   @unique
  tenantId      String
  bankName      String
  accountName   String
  accountNumber String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  bankCode      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendor        Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Order {
  id                 String               @id @default(cuid())
  userId             String
  customerEmail      String
  createdAt          DateTime             @default(now())
  status             OrderStatus          @default(PENDING)
  paymentMethod      String
  totalAmount        Decimal
  currency           String
  paymentProvider    PaymentProvider
  paymentReference   String               @unique
  shippingAddressId  String
  paymentStatus      PaymentStatus        @default(PENDING)
  tenantId           String
  vendorId           String?
  refundStatus       RefundStatus         @default(NONE)
  paymentTxRef       String?
  storeMode          StoreMode            @default(SINGLE_VENDOR)
  couponId           String?
  discountAmount     Decimal              @default(0)
  commissionAmount   Decimal              @default(0)
  coupon             Coupon?              @relation(fields: [couponId], references: [id])
  shippingAddress    Address              @relation(fields: [shippingAddressId], references: [id])
  tenant             Tenant               @relation(fields: [tenantId], references: [id])
  user               User                 @relation(fields: [userId], references: [id])
  vendor             Vendor?              @relation(fields: [vendorId], references: [id])
  items              OrderItem[]
  orderStatusHistory OrderStatusHistory[]
  orderTrackingEvent OrderTrackingEvent[]
  refundRequest      RefundRequest[]
  review             Review[]

  @@index([tenantId, createdAt, status])
}

model OrderItem {
  id           String    @id @default(cuid())
  orderId      String
  productId    String
  quantity     Int
  price        Decimal   @db.Decimal(10, 2)
  tenantId     String
  image        String?
  variantColor String?
  variantId    String?
  variantSize  String?
  vendorId     String?
  storeMode    StoreMode @default(SINGLE_VENDOR)
  order        Order     @relation(fields: [orderId], references: [id])
  product      Product   @relation(fields: [productId], references: [id])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  fullName    String?
  phone       String?
  street      String
  city        String
  state       String?
  postalCode  String?
  country     String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isTemporary Boolean  @default(false)
  isDeleted   Boolean  @default(false)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
}

model Tenant {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  domain             String?
  isDefault          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  autoApproveReviews Boolean             @default(false)
  reviewPolicy       ReviewPolicy        @default(AFTER_PAYMENT)
  email              String?
  logo               String?
  timezone           String              @default("UTC")
  primaryColor       String?
  storeType          StoreType           @default(SINGLE_VENDOR)
  returnPolicy       String?
  shippingPolicy     String?
  aboutTitle         String?
  aboutText          String?
  aboutStory         String?
  aboutImage         String?
  aboutDescription   String?
  aboutContent       String?
  privacyPolicy      String?
  privacyUpdatedAt   DateTime?
  termsOfService     String?
  termsUpdatedAt     DateTime?
  currency           currencyEnum        @default(NGN)
  heroCTA            String?
  heroImage          String?
  heroSubtitle       String?
  heroTitle          String?
  storeMode          StoreMode           @default(SINGLE_VENDOR)
  reviewModeration   Boolean             @default(false)
  country            String
  address            Address[]
  cartItem           CartItem[]
  categories         Category[]
  contact            Contact[]
  coupon             Coupon[]
  tenant             FAQ[]
  newsletter         Newsletter[]
  orders             Order[]
  products           Product[]
  review             Review[]
  users              User[]
  vendors            Vendor[]
  VendorApplication  VendorApplication[]
  vendorBankAccounts VendorBankAccount[]
  vendorPayouts      VendorPayout[]
  WishlistItem       WishlistItem[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  userAgent    String?
  ipAddress    String?
  deviceName   String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Review {
  id                      String                    @id @default(cuid())
  userId                  String
  rating                  Int
  comment                 String
  createdAt               DateTime                  @default(now())
  productId               String
  tenantId                String
  orderId                 String?
  updatedAt               DateTime                  @updatedAt
  status                  ReviewStatus              @default(PENDING)
  repliedAt               DateTime?
  reply                   String?
  helpfulCount            Int                       @default(0)
  images                  String[]
  title                   String?
  verifiedPurchase        Boolean                   @default(false)
  storeMode               StoreMode                 @default(SINGLE_VENDOR)
  deletedAt               DateTime?
  order                   Order?                    @relation(fields: [orderId], references: [id])
  product                 Product                   @relation(fields: [productId], references: [id])
  tenant                  Tenant                    @relation(fields: [tenantId], references: [id])
  user                    User                      @relation(fields: [userId], references: [id])
  reviewModerationHistory ReviewModerationHistory[]

  @@unique([userId, productId])
  @@index([tenantId])
}

model ReviewModerationHistory {
  id        String   @id @default(cuid())
  reviewId  String
  action    String
  note      String?
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id])

  @@index([reviewId])
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  quantity  Int
  tenantId  String
  product   Product @relation(fields: [productId], references: [id])
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model WishlistItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  tenantId  String
  product   Product @relation(fields: [productId], references: [id])
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@index([tenantId])
}

model Category {
  id         String    @id @default(cuid())
  name       String
  slug       String    @unique
  image      String?
  tenantId   String
  isFeatured Boolean   @default(true)
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  products   Product[]
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([email, tenantId])
}

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  message   String
  tenantId  String
  createdAt DateTime      @default(now())
  priority  Priority      @default(NORMAL)
  tag       ContactTag?
  updatedAt DateTime      @updatedAt
  status    ContactStatus @default(UNREAD)
  storeMode StoreMode     @default(SINGLE_VENDOR)
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("General")
  order     Int      @default(0)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  message   String?
  location  String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

model OrderTrackingEvent {
  id          String            @id @default(cuid())
  orderId     String
  tenantId    String
  type        TrackingEventType
  status      OrderStatus?
  title       String
  description String?
  location    String?
  metadata    Json?
  createdAt   DateTime          @default(now())
  order       Order             @relation(fields: [orderId], references: [id])
}

model RefundRequest {
  id              String              @id @default(cuid())
  tenantId        String
  orderId         String
  userId          String
  vendorId        String?
  status          RefundStatus        @default(REQUESTED)
  reason          String
  description     String?
  requestedAmount Float
  approvedAmount  Float?
  currency        String
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  storeMode       StoreMode
  items           RefundItem[]
  order           Order               @relation(fields: [orderId], references: [id])
  user            User                @relation(fields: [userId], references: [id])
  transactions    RefundTransaction[]
}

model RefundItem {
  id              String        @id @default(cuid())
  refundRequestId String
  productId       String
  quantity        Int
  priceAtPurchase Float
  product         Product       @relation(fields: [productId], references: [id])
  refundRequest   RefundRequest @relation(fields: [refundRequestId], references: [id])
}

model RefundTransaction {
  id              String        @id @default(cuid())
  refundRequestId String
  provider        String
  transactionRef  String?
  status          String
  createdAt       DateTime      @default(now())
  refundRequest   RefundRequest @relation(fields: [refundRequestId], references: [id])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  color     String?
  size      String?
  price     Float
  image     String?
  stock     Int      @default(0)
  createdAt DateTime @default(now())
  colorHex  String?
  product   Product  @relation(fields: [productId], references: [id])
}

model Coupon {
  id            String     @id @default(cuid())
  code          String     @unique
  description   String?
  type          CouponType
  value         Decimal
  minimumAmount Decimal?
  usageLimit    Int?
  usedCount     Int        @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  active        Boolean    @default(true)
  tenantId      String
  vendorId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  vendor        Vendor?    @relation(fields: [vendorId], references: [id])
  orders        Order[]
}

model VendorPayout {
  id            String       @id @default(cuid())
  vendorId      String
  tenantId      String
  amount        Decimal
  status        PayoutStatus @default(PENDING)
  reference     String?
  bankName      String?
  accountName   String?
  accountNumber String?
  note          String?
  requestedAt   DateTime     @default(now())
  approvedAt    DateTime?
  paidAt        DateTime?
  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  vendor        Vendor       @relation(fields: [vendorId], references: [id])

  @@index([vendorId, status])
  @@index([tenantId, status])
}

model StoreFollow {
  id        String   @id @default(cuid())
  userId    String
  vendorId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vendor    Vendor? @relation(fields: [vendorId], references: [id], onDelete: Cascade)


  @@unique([userId, vendorId])
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

enum ContactTag {
  BUG
  ORDER
  REFUND
  GENERAL
}

enum Role {
  USER
  ADMIN
  OWNER
  Vendor
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  FAILED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum StoreType {
  SINGLE_VENDOR
  MULTI_VENDOR
}

enum currencyEnum {
  NGN
  USD
  KES
  GHS
  ZAR
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StoreMode {
  SINGLE_VENDOR
  MULTI_VENDOR
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum ReviewPolicy {
  AFTER_PAYMENT
  AFTER_DELIVERY
  MANUAL_APPROVAL
}

enum TrackingEventType {
  STATUS_CHANGE
  COURIER_UPDATE
  NOTE
  SYSTEM
}

enum ContactStatus {
  UNREAD
  READ
  RESOLVED
}

enum RefundStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PROCESSING
  REFUNDED
  FAILED
  NONE
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum VendorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  PERCENTAGE
  FIXED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}
